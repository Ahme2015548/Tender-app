# 🌐 CLOUD DEPLOYMENT: Environment Variables Template
# Copy this file to .env for local development
# Set these variables in your cloud platform dashboard

# Server Configuration
NODE_ENV=production
PORT=3001
HOST=0.0.0.0
TZ=Asia/Riyadh

# Firebase Configuration (REQUIRED for cloud deployment)
# Get this from your Firebase project settings > Service accounts
# Format: Copy the entire service account JSON as a single line string
FIREBASE_SERVICE_ACCOUNT_KEY='{"type":"service_account","project_id":"your-project","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk-...","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"https://www.googleapis.com/..."}'

# Optional: API Keys for external integrations
# TIMER_API_KEY=your-api-key-here

# Optional: Webhook URLs for notifications
# WEBHOOK_URL=https://your-webhook-url.com/timer-notifications