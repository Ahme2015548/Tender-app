{
  "version": 2,
  "builds": [
    {
      "src": "timer-api.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "timer-api.js"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "TZ": "Asia/Riyadh"
  },
  "functions": {
    "timer-api.js": {
      "maxDuration": 30
    }
  }
}